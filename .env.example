# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. For production use Neon, Supabase, or Railway.
# Example (Neon): postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/confluentx?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/confluentx"

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32  (or `npx auth secret`)
AUTH_SECRET="replace-with-a-32-byte-random-secret"
# Only needed when deploying behind a proxy or non-standard host:
# AUTH_URL="https://app.confluentx.com"
AUTH_TRUST_HOST="true"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Future providers (placeholders — wire up in src/auth.config.ts when ready)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── Market data (Databento) ─────────────────────────────────────────────────
# Professional CME futures feed — https://databento.com → API keys.
# Leave empty to fall back to Yahoo (delayed) / mock for futures.
# Dataset GLBX.MDP3 must be enabled on the account.
DATABENTO_API_KEY=""
# DATABENTO_DATASET="GLBX.MDP3"

# ── Email (Resend) ──────────────────────────────────────────────────────────
# https://resend.com/api-keys — leave empty in dev to log emails to console.
RESEND_API_KEY=""
MAIL_FROM="ConfluentX <onboarding@resend.dev>"

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
