// ConfluentX — Prisma schema
// PostgreSQL. JWT session strategy (NextAuth v5) with database-backed
// verification / reset / 2FA tokens and device session auditing.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────── Auth ──────

enum UserRole {
  USER
  ADMIN
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               UserRole  @default(USER)
  isTwoFactorEnabled Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts              Account[]
  twoFactorConfirmation TwoFactorConfirmation?
  deviceSessions        DeviceSession[]
  watchlistItems        WatchlistItem[]
  alerts                Alert[]
  journalEntries        JournalEntry[]
  settings              UserSettings?
  subscription          Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// One-time token emailed to verify account ownership.
model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

/// One-time token emailed for password resets.
model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

/// Short-lived 6-digit code emailed for two-factor login.
model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

/// Marker that the user passed 2FA for the current credentials sign-in.
/// Consumed (deleted) by the signIn callback.
model TwoFactorConfirmation {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Devices that have signed in — powers "new device" alert emails
/// and the account security page.
model DeviceSession {
  id           String   @id @default(cuid())
  userId       String
  fingerprint  String // hash of user-agent + coarse IP
  browser      String?
  os           String?
  ip           String?
  userAgent    String?  @db.Text
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
}

// ──────────────────────────────────────────────────────────── Trading ──────

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  symbol    String // e.g. NQ, ES, MNQ, MES, CL, GC, YM, RTY
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
}

enum AlertCondition {
  PRICE_ABOVE
  PRICE_BELOW
  CROSSES
}

model Alert {
  id        String         @id @default(cuid())
  userId    String
  symbol    String
  condition AlertCondition
  price     Float
  note      String?
  active    Boolean        @default(true)
  triggered Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum TradeSide {
  LONG
  SHORT
}

model JournalEntry {
  id         String    @id @default(cuid())
  userId     String
  symbol     String
  side       TradeSide
  quantity   Int
  entryPrice Float
  exitPrice  Float?
  pnl        Float?
  fees       Float     @default(0)
  setup      String? // e.g. "Opening Range Break", "VWAP Reclaim"
  notes      String?   @db.Text
  tags       String[]  @default([])
  executedAt DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, executedAt])
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  defaultSymbol    String   @default("NQ")
  defaultTimeframe String   @default("5m")
  chartType        String   @default("candles")
  showVolume       Boolean  @default(true)
  showVwap         Boolean  @default(true)
  emaFast          Int      @default(9)
  emaSlow          Int      @default(21)
  riskPerTradePct  Float    @default(1.0)
  dailyLossLimit   Float    @default(1000)
  maxContracts     Int      @default(5)
  emailAlerts      Boolean  @default(true)
  emailNewsletter  Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────── Subscription ─────

enum PlanTier {
  FREE
  PRO
  INSTITUTIONAL
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 PlanTier           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
